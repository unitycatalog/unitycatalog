# TLS gateway for the Celonis OAuth server local issuer (https://dev.dev.celonis.cloud).
# Maps the production-style hostname to the oauth-server container on port 9099.
# Default tenant headers allow OIDC discovery/JWKS without per-client team context (local tests).
dev.dev.celonis.cloud {
	tls internal
	reverse_proxy oauth-server:9099 {
		header_up X-Celonis-Team-Id 79257834-828d-48cb-951d-75294d6e1cce
		header_up X-Celonis-Team-Domain dev
	}
}
