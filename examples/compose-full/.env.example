# OIDC provider configuration
# See ../../etc/envoy/examples/ for provider-specific templates (Okta, Entra ID, Keycloak).
OIDC_PROVIDER_DOMAIN=
OIDC_AUTHORIZATION_ENDPOINT=
OIDC_TOKEN_ENDPOINT=
OIDC_JWKS_URI=
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Optional OIDC settings (defaults shown)
OIDC_SCOPES=openid profile email
OIDC_CALLBACK_PATH=/callback
# OIDC_HMAC_SECRET=          # random value generated at startup if empty

# PostgreSQL credentials (shared between the postgres container and hibernate.properties)
POSTGRES_USER=uc_default_user
POSTGRES_PASSWORD=uc_default_password
